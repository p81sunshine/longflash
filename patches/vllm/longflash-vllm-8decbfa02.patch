+    def _new_suffix_matcher_from_input_batch(
+        self,
+        input_batch: Any,
+        req_id: str,
+        sampled_ids: list[int],
+    ) -> DFlashSuffixMatcher:
+        req_index = input_batch.req_id_to_index[req_id]
+        num_tokens = int(input_batch.num_tokens_no_spec[req_index])
+        token_ids = [
+            int(token_id)
