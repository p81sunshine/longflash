+    def _propose_suffix_draft_for_request(
+        self,
+        input_batch: Any,
+        req_id: str,
+        sampled_ids: list[int],
+    ) -> list[int] | None:
+        req_index = input_batch.req_id_to_index[req_id]
+        if not sampled_ids:
+            return None
+        if int(input_batch.num_computed_tokens_cpu[req_index]) < int(
+            input_batch.num_prompt_tokens[req_index]
+        ):
+            return None
+
+        matcher = self._dflash_suffix_matchers.get(req_id)
+        if matcher is None:
+            matcher = self._new_suffix_matcher_from_input_batch(
+                input_batch,
+                req_id,
+                sampled_ids,
+            )
+            self._dflash_suffix_matchers[req_id] = matcher
+        matcher.extend(sampled_ids)
+
+        remaining = int(self.max_model_len) - len(matcher) - 1
+        max_predict_len = min(
+            int(self.num_speculative_tokens),
+            int(self.dflash_suffix_max_predict_len),
+            remaining,
+        )
+        if max_predict_len <= 0:
+            return None
+
+        prediction = matcher.predict(
+            max_predict_len=max_predict_len,
+            max_query_len=self.dflash_suffix_max_query_len,
+            min_query_len=self.dflash_suffix_min_query_len,
+            alpha=self.dflash_suffix_alpha,
+            max_spec_offset=self.dflash_suffix_max_spec_offset,
+            min_token_prob=self.dflash_suffix_min_token_prob,
+            max_match_count=self.dflash_suffix_max_matches,
+        )
+        self._dflash_last_suffix_prediction = prediction
+        if not prediction.is_high_confidence(threshold=self.dflash_suffix_threshold):
+            return None
+
+        tokens = prediction.tokens[:max_predict_len]
+        if not tokens:
+            return None
+        if os.environ.get("DFLASH_DEBUG_SUFFIX"):
+            logger.warning(
+                "DFlash suffix hit req=%s len=%s path_score=%.4f tree_score=%.4f query=%s support=%s",
+                req_id,
+                len(tokens),
+                prediction.best_path_score,
+                prediction.score,
+                prediction.query_len,
+                prediction.support,
+            )
+        return [int(token_id) for token_id in tokens]
+
