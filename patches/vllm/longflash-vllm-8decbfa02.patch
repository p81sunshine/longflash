+
+    def propose_suffix_draft_rows(
+        self,
+        input_batch: Any,
+        sampled_token_ids: list[list[int]],
+        *,
+        pad_hits: bool = False,
+    ) -> list[list[int] | None] | None:
+        if not self.dflash_suffix_decoding:
+            return None
+
+        req_ids = input_batch.req_ids
+        self._drop_inactive_suffix_matchers(req_ids)
+        if len(req_ids) == 0 or len(req_ids) != len(sampled_token_ids):
+            return None
