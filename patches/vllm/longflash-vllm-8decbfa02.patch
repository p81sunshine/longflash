+    def _drop_inactive_suffix_matchers(self, active_req_ids: list[str]) -> None:
+        active = set(active_req_ids)
+        for req_id in list(self._dflash_suffix_matchers):
+            if req_id not in active:
+                del self._dflash_suffix_matchers[req_id]
+
